function titleCase(word: string) {
  return word.charAt(0).toUpperCase() + word.slice(1);
}

function lookupDefinition(term: string) {
  const normalized = normalizeTerm(term);
  return TERM_GLOSSARY[normalized] || TERM_GLOSSARY[normalized.replace(/-/g, '')] || '';
}

function splitStemIntoTarget(stem: string) {
  return cleanStudyText(stem)
    .replace(/^what term describes\s+/i, '')
    .replace(/^which\s+/i, '')
    .replace(/^the\s+/i, '')
    .replace(/\s+is defined as:?$/i, '')
    .replace(/\s+is:?$/i, '')
    .replace(/\?$/, '')
    .trim();
}

function conceptFromQuestion(stem: string, answer: string) {
  const answerDef = lookupDefinition(answer);
  const lower = stem.toLowerCase();

  if (/unit of radioactivity/.test(lower) && /nuclear medicine/i.test(answer)) {
    return 'Nuclear medicine is correct because it uses radiopharmaceuticals, so activity is measured with units such as the becquerel (Bq).';
  }
  if (/high-voltage section.*transformer/.test(lower) && /step-up/i.test(answer)) {
    return 'A step-up transformer is correct because the high-voltage section must raise voltage dramatically so electrons can be accelerated from cathode to anode.';
  }
  if (/mutual induction/.test(lower) && /transformer/i.test(answer)) {
    return 'Transformers are correct because mutual induction is the transfer of energy between primary and secondary coils, which is exactly how transformers operate.';
  }
  if (/consistency of radiographic exposure/.test(lower) && /(aec|automatic exposure control)/i.test(answer)) {
    return 'Automatic exposure control (AEC) is correct because it stops the exposure once the receptor has received enough radiation, helping keep image receptor exposure consistent from exam to exam.';
  }
  if (/longitudinal mucosal folds.*stomach/.test(lower) && /rugae/i.test(answer)) {
    return 'Rugae are correct because they are the normal longitudinal folds in the gastric mucosa seen inside the stomach.';
  }
  if (/needle-stick/.test(lower) && /uncapped into sharps containers/i.test(answer)) {
    return 'Uncapped into sharps containers is correct because used sharps should go directly into a puncture-resistant sharps container without recapping.';
  }
  if (/smallest unit of an element/.test(lower) && /atom/i.test(answer)) {
    return 'An atom is correct because it is the smallest unit that still keeps the chemical identity of an element.';
  }
  if (/atomic mass/.test(lower) && /sum of protons and neutrons/i.test(answer)) {
    return 'Atomic mass is correct because it refers to the total number of protons and neutrons found in the nucleus.';
  }
  if (/becquerel/.test(lower) && /nuclear medicine/i.test(answer)) {
    return 'Nuclear medicine is correct because radiopharmaceutical activity is measured in becquerels, the SI unit of radioactivity.';
  }
  if (/minor calyces/i.test(answer) && /collecting tubules|major calyces|urine/i.test(lower)) {
    return 'Minor calyces are correct because they collect urine from the papillae and funnel it into the major calyces.';
  }
  if (answerDef) return `${titleCase(cleanStudyText(answer))} ${answerDef}`;

  const target = splitStemIntoTarget(stem);
  if (target && /^what term describes/i.test(stem)) return `${titleCase(cleanStudyText(answer))} describes ${target}.`;
  if (target && /^which device/i.test(stem)) return `${titleCase(cleanStudyText(answer))} is the device that ${target}.`;
  if (target && /^which structure/i.test(stem)) return `${titleCase(cleanStudyText(answer))} is the structure that ${target}.`;
  if (target && /^which structures/i.test(stem)) return `${titleCase(cleanStudyText(answer))} are the structures that ${target}.`;
  if (target && /^which segment/i.test(stem)) return `${titleCase(cleanStudyText(answer))} is the segment that ${target}.`;
  if (target && /^the .* are called/i.test(lower)) return `${titleCase(cleanStudyText(answer))} is the correct term for ${target}.`;

  return `${titleCase(cleanStudyText(answer))} is the correct answer.`;
}

function isGenericText(text: string) {
  return /best matches the question stem|best answer here|directly matches the concept being tested|testing the standard definition or function of that term|review how this term fits|correct answer is .*question\.?$/i.test(text);
}

function buildWrongChoiceHelp(q: any) {
  const choices = normalizeChoices(q?.choices || []);
  const correctKey = String(q?.correctAnswer || q?.correct || q?.answer || '').trim().toUpperCase();
  const pieces: string[] = [];
  for (const choice of choices) {
    if (choice.key === correctKey) continue;
    const def = lookupDefinition(choice.text);
    if (!def) continue;
    pieces.push(`${choice.text} ${def}`);
    if (pieces.length >= 3) break;
  }
  if (!pieces.length) return '';
  return ` ${pieces.join(' ')}`;
}

export function buildRationale(q: any): string {
  const explicit = String(
    q?.flash_rationale ||
      q?.explanation?.whyCorrect ||
      q?.whyCorrect ||
      q?.rationale ||
      q?.explanation ||
      ''
  ).trim();

  const stem = getQuestionStem(q);
  const answer = getCorrectChoiceText(q);

  const correctPart = explicit && !isGenericText(explicit) ? cleanStudyText(explicit) : conceptFromQuestion(stem, answer);
  const wrongChoicePart = buildWrongChoiceHelp(q);

  return cleanStudyText(`${correctPart}${wrongChoicePart}`);
}

export function flashcardFrontForQuestion(q: Question): string {
  const explicitFront = String((q as any).flash_front || '').trim();
  if (explicitFront) return cleanStudyText(explicitFront);
  return getQuestionStem(q);
}

export function flashcardBackForQuestion(q: Question): string {
  const explicitBack = String((q as any).flash_back || '').trim();
  if (explicitBack) return cleanStudyText(explicitBack);
  return getCorrectChoiceText(q);
}
