import type { Question } from '@/lib/questions';
import { normalizeChoices } from '@/lib/normalizeChoices';

export function cleanStudyText(text: string): string {
  return String(text || '')
    .replace(/My ARRT Challenge Test.*$/gi, '')
    .replace(/Original content\s+—\s+not for resale.*$/gi, '')
    .replace(/PROCEDURES Questions\s*\d+[–-]\d+/gi, '')
    .replace(/PATIENT CARE Questions\s*\d+[–-]\d+/gi, '')
    .replace(/\s+/g, ' ')
    .trim();
}

export function getQuestionStem(q: any): string {
  return cleanStudyText(String(q?.stem || q?.question || q?.prompt || ''));
}

export function getCorrectChoiceText(q: any): string {
  const choices = normalizeChoices(q?.choices || []);
  const correctKey = String(
    q?.correctAnswer || q?.correct || q?.answer || q?.correctKey || q?.answerKey || ''
  )
    .trim()
    .toUpperCase();

  const choice = choices.find((c) => c.key === correctKey);
  if (choice?.text) return cleanStudyText(choice.text);
  return cleanStudyText(correctKey);
}

function normalizeTerm(term: string) {
  return cleanStudyText(term)
    .toLowerCase()
    .replace(/^[a-d]\.?\s*/, '')
    .replace(/\s*\([^)]*\)/g, '')
    .replace(/[.,:;]+$/g, '')
    .trim();
}

